# PIA credentials — https://www.privateinternetaccess.com/pages/client-control-panel
PIA_USER=p1234567
PIA_PASS=your_password_here

# VPN regions — one per container, one HTTP proxy per region.
# Add/remove entries and re-run: uv run python scripts/generate_compose.py
# Full list: docker run --rm qmcgaw/gluetun format-servers -private-internet-access
VPN_REGION_1="Singapore"
VPN_REGION_2="JP Tokyo"
VPN_REGION_3="Taiwan"
VPN_REGION_4="Hong Kong"
VPN_REGION_5="South Korea"
VPN_REGION_6="Malaysia"
